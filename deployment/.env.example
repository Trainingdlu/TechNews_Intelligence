POSTGRES_USER=myuser
POSTGRES_PASSWORD=strong_password
POSTGRES_DB=warehouse

N8N_USER=admin
N8N_PASSWORD=password

POSTGRES_PORT=5432
N8N_PORT=5678
METABASE_PORT=3000

GEMINI_API_KEY=AI-placeholder
GEMINI_MODEL=gemini-2.5-pro
AGENT_RUNTIME=langchain
AGENT_RUNTIME_STRICT=false
AGENT_MAX_ITERATIONS=16
AGENT_TEMPERATURE=0.1
AGENT_ROUTE_METRICS=true
AGENT_ROUTE_LOG_EVERY=20
TIMELINE_MIN_EVENTS=5
LANDSCAPE_MIN_URLS=4
LANDSCAPE_MIN_MATCHED_ARTICLES=6
LANDSCAPE_MIN_ACTIVE_ENTITIES=2
DEEPSEEK_API_KEY=sk-placeholder

JINA_API_KEY=jina_placeholder

TELEGRAM_BOT_TOKEN=yuor_bot_token_here
# Comma-separated Telegram user IDs allowed to run admin commands (/settings, /quota)
TELEGRAM_ADMIN_IDS=
BOT_RATE_LIMIT=3
BOT_RATE_WINDOW_SEC=10
BOT_AUTO_DELETE_SEC=30
BOT_SEND_RETRY_ATTEMPTS=2
BOT_SEND_RETRY_BASE_SEC=0.8

API_PORT=8000
CORS_ORIGINS=https://agent.trainingcqy.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ADMIN_EMAIL=your_email@gmail.com
API_BASE_URL=https://agentapi.trainingcqy.com
TIMEZONE=Asia/Shanghai

# Useful for local development if you are behind a firewall (e.g., GFW).
# If running on Cloud/VPS, leave these EMPTY. Example: http://host.docker.internal:7890
HTTP_PROXY=
HTTPS_PROXY=


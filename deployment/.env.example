# =========================
# Ports / Base Stack
# =========================
POSTGRES_PORT=5432
N8N_PORT=5678
METABASE_PORT=3000
API_PORT=8000

# =========================
# Postgres
# =========================
POSTGRES_USER=myuser
POSTGRES_PASSWORD=strong_password
POSTGRES_DB=warehouse

# =========================
# n8n
# =========================
N8N_USER=admin
N8N_PASSWORD=password
# Optional: used in some workflow notifications for editor deep-link
N8N_EDITOR_BASE_URL=http://localhost:5678

# =========================
# Model Provider
# =========================
AGENT_MODEL_PROVIDER=gemini_api

GEMINI_API_KEY=AI-placeholder
GEMINI_MODEL=gemini-2.5-pro

VERTEX_PROJECT=your-gcp-project-id
VERTEX_LOCATION=global
# Gemini 3 Pro model-id `gemini-3-pro-preview` was discontinued on 2026-03-26.
# Prefer the replacement: `gemini-3.1-pro-preview`.
VERTEX_MODEL=gemini-3.1-pro-preview
# Optional fallbacks used by code
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=

# Host path to Vertex service-account JSON (for docker volume mount)
GCP_SA_PATH=/home/trainingcqy/secrets/vertex-sa.json
GOOGLE_APPLICATION_CREDENTIALS=

# =========================
# LangSmith (optional)
# =========================
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=technews-agent-prod
LANGSMITH_WORKSPACE_ID=
LANGCHAIN_TRACING_V2=
LANGCHAIN_PROJECT=

# =========================
# Agent Runtime
# =========================
AGENT_REACT_RECURSION_LIMIT=25
AGENT_TEMPERATURE=0.1
AGENT_STRICT_INLINE_CITATIONS=true
AGENT_ROUTE_METRICS=true
AGENT_ROUTE_LOG_EVERY=20
AGENT_MAX_SOURCE_URLS=12
AGENT_TOPIC_EXPANSIONS_PATH=

# MCP runtime
AGENT_MCP_CLIENT_MODE=local
AGENT_MCP_SERVER_NAME=newsdb
AGENT_MCP_STDIO_COMMAND=
AGENT_MCP_STDIO_CWD=
AGENT_MCP_RPC_TIMEOUT_SEC=20

# =========================
# Retrieval / Rerank
# =========================
JINA_API_KEY=jina_placeholder
# none | cross_encoder | llm_rerank
NEWS_RERANK_MODE=none
SEARCH_NEWS_RERANK_MODE=
FULLTEXT_BATCH_RERANK_MODE=
JINA_CROSS_ENCODER_MODEL=jina-reranker-v2-base-multilingual
JINA_LLM_RERANK_MODEL=jina-reranker-v3
JINA_RERANK_TIMEOUT_SEC=15

# =========================
# Upstream APIs in n8n workflows
# =========================
ALI_API_KEY=ali_placeholder
DEEPSEEK_API_KEY=sk-placeholder

# =========================
# Telegram Bot
# =========================
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Comma-separated Telegram user IDs allowed to run admin commands (/settings, /quota)
TELEGRAM_ADMIN_IDS=
BOT_RATE_LIMIT=3
BOT_RATE_WINDOW_SEC=10
BOT_AUTO_DELETE_SEC=30
BOT_SEND_RETRY_ATTEMPTS=2
BOT_SEND_RETRY_BASE_SEC=0.8
BOT_MAX_CITATION_URLS=12
BOT_SESSION_MAX_CHATS=5000
BOT_SESSION_TTL_SEC=86400
BOT_RATE_TRACK_MAX_CHATS=5000

# =========================
# API Runtime
# =========================
CORS_ORIGINS=https://agent.trainingcqy.com
API_RATE_LIMIT=5
API_RATE_TRACK_MAX_IPS=10000
APPROVE_LINK_SECRET=
SECRET_KEY=
APPROVE_LINK_TTL_SEC=86400

# =========================
# Mail / Notification
# =========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ADMIN_EMAIL=your_email@gmail.com
API_BASE_URL=https://agentapi.trainingcqy.com
TIMEZONE=Asia/Shanghai

# =========================
# Proxy (optional)
# =========================
# Useful for local development if you are behind a firewall (e.g., GFW).
# If running on Cloud/VPS, leave these EMPTY. Example: http://host.docker.internal:7890
HTTP_PROXY=
HTTPS_PROXY=


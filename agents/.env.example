# === Google Gemini ===
GEMINI_API_KEY=your_gemini_api_key_here

# === Jina AI ===
JINA_API_KEY=your_jina_api_key_here

# === PostgreSQL ===
DB_HOST=127.0.0.1
DB_PORT=5555
DB_NAME=DB
DB_USER=your_db_user

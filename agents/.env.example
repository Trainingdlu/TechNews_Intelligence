# === Google Gemini ===
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro

# === Agent Runtime ===
# langchain (default) | legacy
AGENT_RUNTIME=langchain
# true: LangChain errors fail fast; false: fallback to legacy runtime
AGENT_RUNTIME_STRICT=false
# tool-call recursion limit for LangGraph runtime
AGENT_MAX_ITERATIONS=16
# model temperature for LangChain runtime
AGENT_TEMPERATURE=0.1
# route metrics logs (hit rate): true/false
AGENT_ROUTE_METRICS=true
# print one metrics line every N requests (fallback always prints immediately)
AGENT_ROUTE_LOG_EVERY=20
# minimum timeline events required for deep analysis; below this returns factual timeline only
TIMELINE_MIN_EVENTS=5
# minimum evidence thresholds for landscape analysis fallback
LANDSCAPE_MIN_URLS=4
LANDSCAPE_MIN_MATCHED_ARTICLES=6
LANDSCAPE_MIN_ACTIVE_ENTITIES=2

# === Jina AI ===
JINA_API_KEY=your_jina_api_key_here

# === PostgreSQL ===
DB_HOST=127.0.0.1
DB_PORT=5555
DB_NAME=DB
DB_USER=your_db_user
DB_PASS=your_db_password

# === Network Proxy (optional, leave empty if not needed) ===
HTTP_PROXY=
HTTPS_PROXY=

# === Telegram Bot (optional) ===
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to run admin commands (/settings, /quota)
TELEGRAM_ADMIN_IDS=
# Rate limit for normal chat messages: max requests per window seconds
BOT_RATE_LIMIT=3
BOT_RATE_WINDOW_SEC=10
# Auto-delete seconds for sensitive /quota command messages (0 to disable)
BOT_AUTO_DELETE_SEC=30
# Reply send retry for Telegram transient failures
BOT_SEND_RETRY_ATTEMPTS=2
BOT_SEND_RETRY_BASE_SEC=0.8
# Max URLs to turn into inline citations [1][2][3] per response
BOT_MAX_CITATION_URLS=12

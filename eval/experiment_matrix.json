{
  "name": "task_eval_v1_matrix",
  "description": "Six-group matrix for task-driven layered evaluation (v1).",
  "runner": "task_eval_v1",
  "runner_script": "run_task_eval_v1.py",
  "baseline_group": "G0_baseline",
  "frozen_dataset_version": "v_task_latest",
  "default_runner_args": [],
  "groups": [
    {
      "id": "G0_baseline",
      "description": "R0 + A0 baseline",
      "env": {
        "EVAL_RETRIEVAL_VARIANT": "baseline",
        "EVAL_AGENT_VARIANT": "baseline",
        "NEWS_RERANK_MODE": "none"
      }
    },
    {
      "id": "G1_recall_only",
      "description": "Recall optimization only; rerank off; agent baseline",
      "env": {
        "EVAL_RETRIEVAL_VARIANT": "recall_optimized",
        "EVAL_AGENT_VARIANT": "baseline",
        "NEWS_RERANK_MODE": "none"
      }
    },
    {
      "id": "G2_rerank_only",
      "description": "Rerank optimization only; recall baseline; agent baseline",
      "env": {
        "EVAL_RETRIEVAL_VARIANT": "rerank_optimized",
        "EVAL_AGENT_VARIANT": "baseline",
        "NEWS_RERANK_MODE": "llm_rerank"
      }
    },
    {
      "id": "G3_retrieval_full",
      "description": "Recall + rerank optimization; agent baseline",
      "env": {
        "EVAL_RETRIEVAL_VARIANT": "retrieval_full_optimized",
        "EVAL_AGENT_VARIANT": "baseline",
        "NEWS_RERANK_MODE": "llm_rerank"
      }
    },
    {
      "id": "G4_agent_only",
      "description": "Agent optimization only; retrieval baseline",
      "env": {
        "EVAL_RETRIEVAL_VARIANT": "baseline",
        "EVAL_AGENT_VARIANT": "agent_optimized",
        "NEWS_RERANK_MODE": "none"
      }
    },
    {
      "id": "G5_full_optimized",
      "description": "Retrieval full optimization + agent optimization",
      "env": {
        "EVAL_RETRIEVAL_VARIANT": "retrieval_full_optimized",
        "EVAL_AGENT_VARIANT": "agent_optimized",
        "NEWS_RERANK_MODE": "llm_rerank"
      }
    }
  ]
}

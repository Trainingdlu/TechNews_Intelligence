# =========================
# Model Provider
# =========================
# gemini_api (default) | vertex
AGENT_MODEL_PROVIDER=gemini_api

# Gemini Developer API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro

# Vertex AI (used when AGENT_MODEL_PROVIDER=vertex)
VERTEX_PROJECT=your-gcp-project-id
VERTEX_LOCATION=global
# Gemini 3 Pro model-id `gemini-3-pro-preview` was discontinued on 2026-03-26.
# Prefer the replacement: `gemini-3.1-pro-preview`.
VERTEX_MODEL=gemini-3.1-pro-preview
# Optional fallbacks used by code when VERTEX_* is empty
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
# Optional: local service-account JSON path for ADC.
GOOGLE_APPLICATION_CREDENTIALS=

# =========================
# LangSmith (optional)
# =========================
# Set to true to enable tracing in LangChain/LangGraph runtime
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=technews-agent-local
# Needed only when one API key is bound to multiple workspaces
LANGSMITH_WORKSPACE_ID=
# Optional compatibility flags
LANGCHAIN_TRACING_V2=
LANGCHAIN_PROJECT=

# =========================
# Agent Runtime
# =========================
# ReAct max tool-call rounds per request
AGENT_REACT_RECURSION_LIMIT=25
AGENT_TEMPERATURE=0.1
AGENT_STRICT_INLINE_CITATIONS=true
AGENT_ROUTE_METRICS=true
AGENT_ROUTE_LOG_EVERY=20
# Optional: cap source URLs kept in final answer (fallbacks to BOT_MAX_CITATION_URLS)
AGENT_MAX_SOURCE_URLS=12
# Optional: custom topic expansion config path
AGENT_TOPIC_EXPANSIONS_PATH=

# =========================
# Retrieval / Rerank
# =========================
JINA_API_KEY=your_jina_api_key_here
# none | cross_encoder | llm_rerank
NEWS_RERANK_MODE=none
# Optional per-tool override; leave empty to follow NEWS_RERANK_MODE
SEARCH_NEWS_RERANK_MODE=
FULLTEXT_BATCH_RERANK_MODE=
# Optional model overrides
JINA_CROSS_ENCODER_MODEL=jina-reranker-v2-base-multilingual
JINA_LLM_RERANK_MODEL=jina-reranker-v3
# Jina rerank API timeout in seconds (3~60)
JINA_RERANK_TIMEOUT_SEC=15

# =========================
# MCP Runtime (optional)
# =========================
# local (default) | stdio
AGENT_MCP_CLIENT_MODE=local
AGENT_MCP_SERVER_NAME=newsdb
AGENT_MCP_STDIO_COMMAND=
AGENT_MCP_STDIO_CWD=
AGENT_MCP_RPC_TIMEOUT_SEC=20

# =========================
# PostgreSQL
# =========================
DB_HOST=127.0.0.1
DB_PORT=5555
DB_NAME=DB
DB_USER=your_db_user
DB_PASS=your_db_password

# =========================
# API Runtime (when using app.api)
# =========================
ADMIN_EMAIL=
API_BASE_URL=http://localhost:8000
# approve-link secret; falls back to SECRET_KEY when empty
APPROVE_LINK_SECRET=
SECRET_KEY=
APPROVE_LINK_TTL_SEC=86400
API_RATE_LIMIT=5
API_RATE_TRACK_MAX_IPS=10000
CORS_ORIGINS=*

# =========================
# SMTP (used by app.api)
# =========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# =========================
# Telegram Bot (optional)
# =========================
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to run admin commands
TELEGRAM_ADMIN_IDS=
BOT_RATE_LIMIT=3
BOT_RATE_WINDOW_SEC=10
BOT_AUTO_DELETE_SEC=30
BOT_SEND_RETRY_ATTEMPTS=2
BOT_SEND_RETRY_BASE_SEC=0.8
BOT_MAX_CITATION_URLS=12
BOT_SESSION_MAX_CHATS=5000
BOT_SESSION_TTL_SEC=86400
BOT_RATE_TRACK_MAX_CHATS=5000

# =========================
# Network Proxy (optional)
# =========================
HTTP_PROXY=
HTTPS_PROXY=

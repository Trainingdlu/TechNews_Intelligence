# === LLM Provider ===
# gemini_api (default) | vertex
AGENT_MODEL_PROVIDER=gemini_api

# === Gemini Developer API ===
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro

# === Vertex AI (used when AGENT_MODEL_PROVIDER=vertex) ===
VERTEX_PROJECT=your-gcp-project-id
VERTEX_LOCATION=global
# Gemini 3 Pro model-id `gemini-3-pro-preview` was discontinued on 2026-03-26.
# Prefer the replacement: `gemini-3.1-pro-preview`.
VERTEX_MODEL=gemini-3.1-pro-preview
# Optional: local service-account JSON path for ADC.
GOOGLE_APPLICATION_CREDENTIALS=

# === Agent Runtime ===
# ReAct agent recursion limit (max tool-call rounds per request)
AGENT_REACT_RECURSION_LIMIT=25
AGENT_STRICT_INLINE_CITATIONS=true
# model temperature
AGENT_TEMPERATURE=0.1
# route metrics logs: true/false
AGENT_ROUTE_METRICS=true
# print one metrics line every N requests
AGENT_ROUTE_LOG_EVERY=20

# === MCP Runtime (optional) ===
# backend mode: local (default) | stdio
AGENT_MCP_CLIENT_MODE=local
# logical server name for namespaced tools
AGENT_MCP_SERVER_NAME=newsdb
# stdio command override (used when AGENT_MCP_CLIENT_MODE=stdio)
AGENT_MCP_STDIO_COMMAND=
# stdio working directory override
AGENT_MCP_STDIO_CWD=
# per-RPC timeout in seconds
AGENT_MCP_RPC_TIMEOUT_SEC=20

# === Jina AI (vector search) ===
JINA_API_KEY=your_jina_api_key_here

# === PostgreSQL ===
DB_HOST=127.0.0.1
DB_PORT=5555
DB_NAME=DB
DB_USER=your_db_user
DB_PASS=your_db_password

# === Network Proxy (optional, leave empty if not needed) ===
HTTP_PROXY=
HTTPS_PROXY=

# === Telegram Bot (optional) ===
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to run admin commands (/settings, /quota)
TELEGRAM_ADMIN_IDS=
# Rate limit for normal chat messages: max requests per window seconds
BOT_RATE_LIMIT=3
BOT_RATE_WINDOW_SEC=10
# Auto-delete seconds for sensitive /quota command messages (0 to disable)
BOT_AUTO_DELETE_SEC=30
# Reply send retry for Telegram transient failures
BOT_SEND_RETRY_ATTEMPTS=2
BOT_SEND_RETRY_BASE_SEC=0.8
# Max URLs to turn into inline citations [1][2][3] per response
BOT_MAX_CITATION_URLS=12
